node_modules/
dist/
build/
.wrangler/
.dev.vars
.env
.env.local
*.log
.DS_Store
coverage/

# Python / GPU services
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.model_cache/
.eval_out/

# --- Hardening: secrets, build output, tool state (standalone repo) ---
# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/
**/build/

# Cloudflare / Miniflare / Wrangler state (may contain secrets in KV blobs)
.wrangler/
**/.wrangler/
.mf/
**/.mf/

# Vite caches
.vite/
**/.vite/

# Secrets / env (keep .env.example template tracked)
.env
.env.*
*.env
pod.env
**/pod.env
api_keys
*.pem
*.token
*.key
.dev.vars
!.env.example

# Generated render artifacts (exported MP4/WebM/etc.) — large binaries kept locally, not in
# git. The studio writes renders here; see apps/avatar-live/public/generated/README.md for the
# naming convention. (Also enforced by that folder's own .gitignore, which keeps README tracked.)
apps/avatar-live/public/generated/*.mp4
apps/avatar-live/public/generated/*.webm
apps/avatar-live/public/generated/*.mov
apps/avatar-live/public/generated/*.gif

# Misc
*.log
.DS_Store
