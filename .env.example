# LiveAvatarStream environment template.
# Control plane (Cloudflare) secrets are set via `wrangler secret put`, not here.
# This file documents the GPU plane + director LLM + provider tokens.

# --- Director LLM (default Claude Opus 4.8) ---
DIRECTOR_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
DIRECTOR_LLM_MODEL=claude-opus-4-8

# --- GPU provider (offline jobs) ---
GPU_PROVIDER=modal            # modal | runpod | coreweave
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- GPU provider (realtime warm pool) ---
REALTIME_GPU_PROVIDER=runpod  # runpod | coreweave
RUNPOD_API_KEY=
REALTIME_POOL_MIN_WARM=1
REALTIME_POOL_IDLE_TIMEOUT_S=300

# --- Cloudflare Realtime (SFU / TURN) ---
CF_REALTIME_APP_ID=
CF_REALTIME_APP_SECRET=

# --- R2 (S3-compatible) access for GPU services ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# --- Control API base URL (GPU services call back here) ---
CONTROL_API_URL=http://localhost:8787

# --- Shared internal token between control plane and GPU services (no user auth yet) ---
INTERNAL_SERVICE_TOKEN=change-me
