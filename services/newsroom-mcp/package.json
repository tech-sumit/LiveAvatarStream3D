{
  "name": "@las/newsroom-mcp",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Newsroom MCP server: a stdio MCP that generates newscast assets (graphics, montages, music, post production, external media). Studio control lives in the studio's in-browser WebMCP server.",
  "bin": {
    "newsroom-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "smoke": "node dist/scripts/smoke.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "canvas": "^3.2.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.2"
  }
}
