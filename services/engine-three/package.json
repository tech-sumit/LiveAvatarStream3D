{
  "name": "@las/engine-three",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Three.js PerformanceManifest render node for LiveAvatarStream3D",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "render:local": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.679.0",
    "@hono/node-server": "^1.13.2",
    "@las/protocol": "*",
    "canvas": "^3.2.3",
    "gl": "^8.0.2",
    "hono": "^4.6.3",
    "pngjs": "^7.0.0",
    "three": "0.152.2",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/three": "^0.152.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
