# Copy to .env. None of these are required — the app falls back to the browser's
# Web Speech voice and a GPU-free A2F stand-in when they're unset.

# ElevenLabs TTS (real/cloned voice). NOT prefixed with VITE_ so it stays
# server-side: the dev server proxies /eleven/* and injects this as xi-api-key
# (the key never reaches the browser). Get one at https://elevenlabs.io.
ELEVENLABS_API_KEY=

# Optional: Audio2Face-3D HTTP wrapper (services/gpu/a2f) for broadcast-grade
# lip-sync. Exposed to the client (VITE_ prefix) since it's just a URL.
VITE_A2F_URL=

# Cloudflare R2 persistence (projects + audio/video assets). NOT prefixed with
# VITE_: the dev server signs S3 requests server-side (/r2/*) so these secrets
# never reach the browser. Without them the app persists to localStorage instead.
# The bucket (R2_BUCKET, default las-avatar-live) is auto-created on first save.
# R2_ENDPOINT looks like https://<accountid>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=las-avatar-live
