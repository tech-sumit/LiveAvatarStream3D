{
  "name": "@las/avatar-live",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Realtime 3D talking avatar — stream a script, browser-rendered Three.js metahuman speaks it lip-synced in realtime.",
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace @las/protocol && vite build",
    "preview": "vite preview",
    "typecheck": "npm run build --workspace @las/protocol && tsc --noEmit",
    "test": "vitest run",
    "import-avatar": "node scripts/import-avatar.mjs"
  },
  "dependencies": {
    "@las/performer-core": "*",
    "@las/protocol": "*",
    "mediabunny": "^1.49.0",
    "postprocessing": "6.35.6",
    "three": "0.152.2"
  },
  "devDependencies": {
    "@types/three": "0.152.1",
    "aws4fetch": "^1.0.20",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
