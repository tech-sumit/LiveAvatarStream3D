      "id": "open",
      "slug": "cold-open",
      "storyForm": "READER",
      "headline": "Breaking: Anthropic Suspends Two Models",
      "beats": [
        {
          "id": "o1",
          "text": "Good evening. We begin tonight with a major development from Anthropic.",
          "emotion": "serious",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          }
        },
        {
          "id": "o2",
          "text": "The company has suspended all access to its Fable 5 and Mythos 5 models.",
          "emotion": "serious",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          },
          "pause_ms_after": 350
        }
      ]
    },
    {
      "id": "directive",
      "slug": "the-directive",
      "storyForm": "VO",
      "headline": "A Government Export-Control Order",
      "beats": [
        {
          "id": "d1",
          "text": "Anthropic says it received a directive from the United States government at five twenty-one P.M. Eastern.",
          "emotion": "serious",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          }
        },
        {
          "id": "d2",
          "text": "The order cites national security authorities and federal export controls.",
          "emotion": "concerned",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          },
          "pause_ms_after": 300
        }
      ]
    },
