          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          }
        },
        {
          "id": "c2",
          "text": "Anthropic says it reviewed a demonstration showing only minor, previously known vulnerabilities, the kind discoverable in other publicly available models.",
          "emotion": "thoughtful",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          },
          "pause_ms_after": 350
        }
      ]
    },
