      "slug": "who-is-affected",
      "storyForm": "VO",
      "headline": "Who Is Affected",
      "beats": [
        {
          "id": "s1",
          "text": "The suspension applies to all users worldwide, including foreign nationals and Anthropic's own employees.",
          "emotion": "concerned",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          }
        },
        {
          "id": "s2",
          "text": "All of Anthropic's other models remain unaffected.",
          "emotion": "neutral",
          "gesture": "none",
          "camera": {
            "shot": "medium",
            "move": "static"
          },
          "pause_ms_after": 300
        }
